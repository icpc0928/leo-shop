# ============ Leo Shop 環境變數 ============
# 複製此檔案為 .env 並修改

# ============ PostgreSQL ============
POSTGRES_DB=leoshop
POSTGRES_USER=leoshop
POSTGRES_PASSWORD=CHANGE_ME_secure_password

# ============ Backend ============
DB_URL=jdbc:postgresql://leoshop-db:5432/leoshop
DB_USERNAME=leoshop
DB_PASSWORD=CHANGE_ME_secure_password

# JWT（請換成隨機字串）
JWT_SECRET=CHANGE_ME_random_jwt_secret_key_at_least_32_chars
JWT_EXPIRATION=86400000

# Etherscan API Key
ETHERSCAN_API_KEY=Q57FT849EX8G9GYBVUDCK19JJ56219T7YE

# NOWPayments
NOWPAYMENTS_API_KEY=sandbox-key
NOWPAYMENTS_IPN_SECRET=sandbox-secret

# Crypto rate refresh (ms): 3600000=1hr
CRYPTO_RATE_REFRESH=3600000

# ============ Frontend ============
# ⚠️ 改成你的伺服器 IP 或域名
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:8080

# ============ CORS ============
# 允許的前端來源（逗號分隔）
APP_CORS_ORIGINS=http://YOUR_SERVER_IP:3000,http://localhost:3000
